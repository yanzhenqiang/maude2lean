fmod BOOL_RUN is
    sort Bool .
    op true : -> Bool .
    op false : -> Bool .
    op not_ : Bool -> Bool .
    op _and_ : Bool Bool -> Bool .
    vars X Y : Bool .
    eq not_(true) = false .
    eq not_(false) = true .
    eq and(true, X) = X .
    eq and(false, X) = false .
endfm

red not_(true) .
red and(true, false) .
red not_(not_(true)) .
